Cell[BoxData[{
 StyleBox[
  RowBox[{"Electron", " ", "propagator", " ", 
   RowBox[{"(", 
    RowBox[{"proper", " ", "time", " ", "is", " ", "dimensionless"}], ")"}]}],
   "Text"], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    SuperscriptBox["S", "c"], 
    RowBox[{
     StyleBox["(", "Text"], 
     RowBox[{
      SubscriptBox[
       StyleBox["x", "Text"], "2"], 
      StyleBox[",", "Text"], 
      SubscriptBox["x", "1"]}], ")"}]}], "=", 
   RowBox[{
    SuperscriptBox[
     StyleBox["\[CapitalLambda]", "Text"], 
     RowBox[{"4", "-", "D"}]], 
    RowBox[{"\[Integral]", 
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["\[DifferentialD]", "D"], "p"}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"2", "\[Pi]"}], ")"}], "D"]], 
      SubscriptBox["E", "p"], 
      RowBox[{"(", 
       SubscriptBox["x", "2"], ")"}], 
      FractionBox[
       RowBox[{"\[ImaginaryI]", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", "\[Gamma]p", ")"}], "+", "m"}], ")"}]}], 
       RowBox[{
        SuperscriptBox["p", "2"], "-", 
        SuperscriptBox["m", "2"], "+", "\[ImaginaryI]0"}]], 
      SubscriptBox[
       OverscriptBox["E", "_"], "p"], 
      RowBox[{"(", 
       SubscriptBox["x", "1"], ")"}]}]}]}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"x", "=", 
    RowBox[{
     SubscriptBox["x", "2"], "-", 
     SubscriptBox["x", "1"]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"X", "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["x", "1"], "+", 
       SubscriptBox["x", "2"]}], ")"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    SuperscriptBox["\[Xi]", "2"], "=", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["e", "2"], 
       SuperscriptBox["a", "2"]}], 
      SuperscriptBox["m", "2"]]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"[", "\[CapitalLambda]", "]"}], "=", 
    RowBox[{"m", " ", "-", " ", 
     RowBox[{"mass", " ", "scale"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["E", "p"], 
      RowBox[{"(", 
       SubscriptBox["x", "2"], ")"}]}], "=", 
     RowBox[{
      RowBox[{"[", 
       RowBox[{"1", "-", 
        RowBox[{
         FractionBox[
          RowBox[{"e", 
           RowBox[{"(", "\[Gamma]k", ")"}], 
           RowBox[{"(", "\[Gamma]a", ")"}]}], 
          RowBox[{"2", 
           RowBox[{"(", "kp", ")"}]}]], 
         RowBox[{"(", 
          SubscriptBox["kx", "2"], ")"}]}]}], "]"}], 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], 
         RowBox[{"(", 
          RowBox[{
           FormBox[
            FormBox["p",
             TraditionalForm],
            TraditionalForm], 
           FormBox[
            FormBox[
             SubscriptBox["x", "2"],
             TraditionalForm],
            TraditionalForm]}], ")"}]}], "+", 
        RowBox[{"\[ImaginaryI]", 
         FractionBox[
          RowBox[{"e", " ", 
           RowBox[{"(", 
            RowBox[{
             FormBox[
              FormBox["a",
               TraditionalForm],
              TraditionalForm], 
             FormBox[
              FormBox["p",
               TraditionalForm],
              TraditionalForm]}], ")"}], " "}], 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{
             FormBox[
              FormBox["k",
               TraditionalForm],
              TraditionalForm], 
             FormBox[
              FormBox["p",
               TraditionalForm],
              TraditionalForm]}], ")"}]}]], 
         SuperscriptBox[
          RowBox[{
           FormBox["(",
            TraditionalForm], 
           FormBox[
            RowBox[{
             FormBox[
              FormBox["k",
               TraditionalForm],
              TraditionalForm], 
             FormBox[
              FormBox[
               SubscriptBox["x", "2"],
               TraditionalForm],
              TraditionalForm]}],
            TraditionalForm], 
           FormBox[")",
            TraditionalForm]}], "2"]}], "+", 
        RowBox[{"\[ImaginaryI]", 
         FractionBox[
          RowBox[{
           SuperscriptBox[
            FormBox[
             FormBox["a",
              TraditionalForm],
             TraditionalForm], "2"], " ", 
           SuperscriptBox["e", "2"], " "}], 
          RowBox[{"6", " ", 
           RowBox[{"(", 
            RowBox[{
             FormBox[
              FormBox["k",
               TraditionalForm],
              TraditionalForm], 
             FormBox[
              FormBox["p",
               TraditionalForm],
              TraditionalForm]}], ")"}]}]], 
