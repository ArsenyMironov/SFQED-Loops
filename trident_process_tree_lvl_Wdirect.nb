Cell[TextData[{
 "This notebook is a supplement for our work \n[Y. V. Selivanov, A. A. \
Mironov, A. I.  Alexeenko, A. M. Fedotov arXiv:2605.12479 (2026)]\n\nThe \
notebook was prepared by  A. A. Mironov and Y. V. Selivanov\n\nThe notebook \
presents a tree-level calculation of the trident process rate (the direct \
term contribution) initiated by a relativistic electron propagaing in a \
strong constant crossed electromagnetic field, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["W", "dir"], " "}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2d9ab87a-2edd-4a52-b994-3c8963179c44"],
